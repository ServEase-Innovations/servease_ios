      "eligibility": {
        "title": "3. Eligibility",
        "content": "You must be at least 18 years old to use our services. By using our platform, you represent that you have the legal capacity to enter into binding contracts."
      },
      "accounts": {
        "title": "4. User Accounts",
        "content": "You are responsible for maintaining the confidentiality of your account credentials. You agree to notify us immediately of any unauthorized use of your account."
      },
      "bookings": {
        "title": "5. Bookings and Payments",
        "content": "All bookings are subject to availability. Payments are processed securely through our payment partners. Prices are subject to change without notice."
      },
      "cancellation": {
        "title": "6. Cancellation and Refunds",
        "content": "Cancellations made at least 24 hours before the scheduled service are eligible for a full refund. Late cancellations may incur charges."
      },
      "conduct": {
        "title": "7. User Conduct",
        "content": "You agree to treat providers with respect and dignity. Harassment, discrimination, or inappropriate behavior will result in account termination."
      },
      "liability": {
        "title": "8. Limitation of Liability",
        "content": "ServEaso acts as an intermediary platform. We are not liable for any damages arising from services provided by third-party providers."
      },
      "changes": {
        "title": "9. Changes to Terms",
        "content": "We reserve the right to modify these terms at any time. Continued use of the platform constitutes acceptance of the modified terms."
      },
      "contact": {
        "title": "10. Contact Information",
        "content": "For questions about these Terms, please contact us at support@serveaso.com."
      }
    }
  },
  "privacy": {
    "title": "Privacy Policy",
    "lastUpdated": "Last Updated: {date}",
    "sections": {
      "introduction": {
        "title": "1. Introduction",
        "content": "ServEaso ('we', 'our', 'us') is committed to protecting your privacy. This Privacy Policy explains how we collect, use, and safeguard your personal information."
      },
      "collection": {
        "title": "2. Information We Collect",
        "content": "We collect information you provide directly, such as name, email, phone number, and address. We also automatically collect usage data and device information."
      },
      "usage": {
        "title": "3. How We Use Your Information",
        "content": "We use your information to provide and improve our services, process payments, communicate with you, and ensure platform security."
      },
      "sharing": {
        "title": "4. Information Sharing",
        "content": "We share information with service providers to fulfill bookings, with payment processors for transactions, and as required by law."
      },
      "security": {
        "title": "5. Data Security",
        "content": "We implement industry-standard security measures to protect your information. However, no method of transmission is 100% secure."
      },
      "rights": {
        "title": "6. Your Rights",
        "content": "You have the right to access, correct, or delete your personal information. You can also opt out of marketing communications."
      },
      "cookies": {
        "title": "7. Cookies and Tracking",
        "content": "We use cookies and similar technologies to enhance your experience and analyze platform usage. You can control cookies through your browser settings."
      },
      "children": {
        "title": "8. Children's Privacy",
        "content": "Our services are not intended for children under 13. We do not knowingly collect information from children."
      },
      "changes": {
        "title": "9. Changes to This Policy",
        "content": "We may update this policy periodically. We will notify you of significant changes through the platform or via email."
      },
      "contact": {
        "title": "10. Contact Us",
        "content": "For privacy-related inquiries, please contact us at privacy@serveaso.com."
      }
    }
  },
