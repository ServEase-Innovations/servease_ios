# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command(
  'node',
  ['-p',
   'require.resolve(
      "react-native/scripts/react_native_pods.rb",
      { paths: [process.argv[1]] }
    )',
   __dir__]
).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

# React Native Firebase (static frameworks)
$RNFirebaseAsStaticFramework = true

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
else
  use_frameworks! :linkage => :static
end

target 'Serveaso' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    # Standard RN post install (must run before pod-specific overrides).
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false
    )

    minimum_ios = '15.1'

    installer.pods_project.build_configurations.each do |bc|
      bc.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = minimum_ios
    end

    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |bc|
        # Align pod deployment targets with the app (Xcode 15/16 rejects very old targets).
        bc.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = minimum_ios
        # Pod libraries must not use app provisioning profiles (CI manual signing).
        bc.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
        bc.build_settings['CODE_SIGNING_REQUIRED'] = 'NO'
        bc.build_settings['PROVISIONING_PROFILE'] = ''
        bc.build_settings['PROVISIONING_PROFILE_SPECIFIER'] = ''
        bc.build_settings['CODE_SIGN_IDENTITY'] = ''
        bc.build_settings['DEVELOPMENT_TEAM'] = ''

        if target.name == 'FirebaseCoreInternal'
          bc.build_settings['SWIFT_VERSION'] = '5.0'
          bc.build_settings['SWIFT_STRICT_CONCURRENCY'] = 'minimal'
        end
      end
    end

    installer.pods_project.targets.each do |target|
      if target.name.start_with?('GoogleUtilities') || target.name.start_with?('Firebase') || target.name.start_with?('GoogleDataTransport') || target.name.start_with?('nanopb')
        target.build_configurations.each do |config|
          config.build_settings['DEFINES_MODULE'] = 'YES'
        end
      end
    end

    # 🔥 FIX FOR RCT-FOLLY + NEW XCODE
    installer.pods_project.targets.each do |target|
      if target.name == 'RCT-Folly'
        target.build_configurations.each do |config|
          config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
          config.build_settings['CLANG_CXX_LIBRARY'] = 'libc++'
          config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
            '$(inherited)',
            'FOLLY_NO_CONFIG',
            'FOLLY_MOBILE=1',
            'FOLLY_USE_LIBCPP=1'
          ]
        end
      end
    end
  end
end
