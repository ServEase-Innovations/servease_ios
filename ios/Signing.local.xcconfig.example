// Copy to Signing.local.xcconfig (gitignored) and fill in your values.
// Find your Team ID in Xcode → Settings → Accounts → [Your Apple ID] → Team ID
// Or: security find-identity -v -p codesigning

DEVELOPMENT_TEAM = YOUR_TEAM_ID_HERE

// Use a unique bundle id under *your* team (the org id com.serveaso.app.ios is reserved for ServEase).
PRODUCT_BUNDLE_IDENTIFIER = com.yourname.serveaso.dev
